# TRAM Environment Variables
# Copy this to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────
TRAM_HOST=0.0.0.0
TRAM_PORT=8765

# ── Pipelines ─────────────────────────────────────────────────────────────
TRAM_PIPELINE_DIR=./pipelines
TRAM_STATE_DIR=./state

# ── Logging ───────────────────────────────────────────────────────────────
TRAM_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
TRAM_LOG_FORMAT=json         # json | text

# ── CLI proxy ─────────────────────────────────────────────────────────────
TRAM_API_URL=http://localhost:8765

# ── Source SFTP (Network Element) ─────────────────────────────────────────
NE_SFTP_HOST=10.0.0.1
NE_SFTP_PORT=22
NE_SFTP_USER=pmuser
NE_SFTP_PASS=

# ── Sink SFTP (Mediation Server) ──────────────────────────────────────────
MED_SFTP_HOST=10.0.0.2
MED_SFTP_PORT=22
MED_SFTP_USER=meduser
MED_SFTP_PASS=
