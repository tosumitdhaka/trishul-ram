# Dockerfile.worker — TRAM worker image
#
# Executes pipelines dispatched by the manager. No scheduling, no UI, no DB persistence.
#
#   ✓  worker       — semantic marker
#   ✓  kafka        — Kafka source/sink
#   ✓  snmp         — pysnmp: SNMP get/walk/trap source+sink (uses MIBs from shared volume)
#   ✓  avro         — Avro serializer/deserializer
#   ✓  protobuf     — protobuf runtime decode (compiled .proto artifacts from manager)
#   ✓  asn1         — ASN.1 BER/DER/PER decode
#   ✓  jmespath     — jmespath transform
#   ✓  sql          — SQL connector (sqlalchemy runtime, no migration/scheduling)
#   ✓  websocket    — WebSocket source/sink
#   ✓  metrics      — Prometheus /metrics endpoint
#   ✓  prometheus_rw — Prometheus remote-write sink
#   ✓  watch        — pipeline config hot-reload
#
#   ✗  manager (apscheduler, persistence) — manager owns scheduling and DB writes
#   ✗  mib (pysmi)  — MIB compilation is manager-side only
#   ✗  protobuf_ser (grpcio-tools) — .proto compilation is manager-side only
#   ✗  k8s          — worker orchestration is manager-side only
#   ✗  Web UI assets, ai-* — UI/API-driven features
#
# Not yet tested (disabled; re-enable per image when validated):
#   mqtt, amqp, nats, gnmi, influxdb, redis, elasticsearch, opensearch
#
# Usage:
#   docker build -f Dockerfile.worker -t trishul-ram-worker:1.3.3 .
#
# Stage 0  builder     — builds the Python wheel
# Stage 1  runtime     — final image (no UI assets, no manager deps)

# ── Stage 0: build wheel ─────────────────────────────────────────────────────
FROM python:3.13-slim AS builder

WORKDIR /build
COPY pyproject.toml README.md ./
COPY tram/ ./tram/

RUN pip install --no-cache-dir build && python -m build --wheel

# ── Stage 1: runtime image ────────────────────────────────────────────────────
FROM python:3.13-slim

# Non-root user — same uid/gid as manager image so shared PVC files are compatible
RUN useradd -m -u 1000 -s /bin/bash tram

WORKDIR /app

# omniORBpy (CORBA) requires the omniORB shared runtime libraries
RUN apt-get update && \
    ( apt-get install -y --no-install-recommends libomniorb4-3t64 libomnithread4 || \
      apt-get install -y --no-install-recommends libomniorb4-2 libomnithread4 ) && \
    rm -rf /var/lib/apt/lists/*

# Install worker extras only — no manager (no apscheduler, no sqlalchemy persistence).
# sql extra is included so workers can execute SQL connector pipelines (needs sqlalchemy).
# Excluded to keep the image lean: s3, gcs, azure, otel, parquet, ai-* (UI-driven features).
# corba (omniORBpy) is excluded: not on PyPI; install python3-omniorb via apt in a custom layer.
COPY --from=builder /build/dist/*.whl .
RUN whl=$(ls *.whl) && \
    pip install --no-cache-dir \
        "${whl}[worker,kafka,snmp,avro,protobuf,asn1,jmespath,sql,websocket,metrics,prometheus_rw,watch]" && \
    rm *.whl

# Copy bundled SNMP MIB assets from the repo
COPY files/mibs_compiled/ /mibs/
COPY files/mibs/ /mib-sources/

# Bundle pipeline templates (read-only reference examples)
COPY pipelines/ /tram-templates/

# Create data, MIB, and schema directories; set ownership
# NOTE: no /ui directory — workers do not serve the web UI
RUN mkdir -p /data /data/mibs /mibs /mib-sources /schemas && \
    mkdir -p /home/tram/.tram && \
    chown -R tram:tram /data /mibs /mib-sources /schemas /home/tram /app

USER tram

# Health check targets the agent endpoint on port 8766
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8766/agent/health')" || exit 1

EXPOSE 8766

ENV TRAM_MIB_DIR=/mibs
ENV TRAM_MIB_BUNDLED_SOURCE_DIR=/mib-sources
ENV TRAM_SCHEMA_DIR=/schemas
ENV TRAM_MODE=worker
ENV TRAM_TEMPLATES_DIR=/tram-templates

ENTRYPOINT ["tram"]
CMD ["daemon"]
